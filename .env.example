# Supabase Configuration
# ----------------------
# URL of your Supabase project (Project Settings -> API -> Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon key for client-side access (Project Settings -> API -> Project API Keys -> anon, public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role key for admin access (Project Settings -> API -> Project API Keys -> service_role, secret)
# WARNING: Never expose this key to the browser! It bypasses Row Level Security (RLS).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
